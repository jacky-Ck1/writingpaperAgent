# ============================================================
# Paper-Writing-Agent Configuration
# Copy to .env and fill in your credentials
# ============================================================

# ---- Provider Selection (uncomment one per layer) ----
LLM_PROVIDER=deepseek
EMBEDDING_PROVIDER=bge
VECTORSTORE_PROVIDER=faiss

# ---- LLM: DeepSeek ----
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- LLM: OpenAI (set LLM_PROVIDER=openai) ----
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# ---- LLM: Local / Ollama (set LLM_PROVIDER=local) ----
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen2.5:7b

# ---- Embedding: BGE (local) ----
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu

# ---- Embedding: OpenAI (set EMBEDDING_PROVIDER=openai) ----
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Embedding: Local (set EMBEDDING_PROVIDER=local) ----
# LOCAL_EMBEDDING_BASE_URL=http://localhost:11434/v1
# LOCAL_EMBEDDING_MODEL=nomic-embed-text

# ---- Vector Store ----
# VECTORSTORE_PROVIDER=faiss
# CHROMA_PERSIST_DIR=data/chroma_db

# ---- Document Processing ----
CHUNK_SIZE=500
CHUNK_OVERLAP=100
SMART_CHUNKING=true

# ---- Retrieval ----
RETRIEVAL_K=3
RETRIEVAL_METHOD=mmr
ENABLE_HYBRID_RETRIEVAL=true

# ---- Paths ----
DATA_DIR=data
MAX_ITERATIONS=3
